# 생성일: 2026-04-15
# 출처: ipsilounge/backend/app/surveys/schemas/high.json
#        (sha256: 6190113239... 시점 — _index.yaml 참조)
#
# 추출 규칙:
#   - high.json 의 모든 category.questions 를 enumerate
#   - type 별 behavior_test 템플릿 적용
#   - auto_calculated / derived 질문은 aspect=auto_calculate + needs_user_decision=true
#   - 이미 high.yaml 에 존재하는 3개 샘플(A4/B1/B5)은 중복 포함하지 않음
#     → 파일 끝 주석 참조
# ===================================================================

meta:
