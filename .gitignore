# 환경변수 / 비밀키 (절대 커밋 금지)
.env
.env.local
.env.production
*.env
firebase-credentials.json
firebase-adminsdk-*.json
google-service-account.json
google-services.json
GoogleService-Info.plist
*.keystore
*.jks
key.properties

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# Node.js
node_modules/
.next/
.vercel/
*.tsbuildinfo

# Flutter / Android
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
build/
android/.gradle/
android/local.properties
mobile/android/.gradle/
mobile/android/local.properties
*.apk
*.aab

# SSL 인증서 (서버에서만 존재)
nginx/ssl/

# IDE
.idea/
.vscode/
*.iml
.claude/

# Claude Code 프로젝트 설정 whitelist
# (개인 local 설정은 여전히 ignore, 팀 공유 설정만 commit)
!analyzer/.claude/
!analyzer/.claude/commands/
!analyzer/.claude/commands/*.md
!analyzer/.claude/settings.json
analyzer/.claude/settings.local.json

# OS
.DS_Store
Thumbs.db

# 임시 파일
temp_*.png
temp_*.jpg
temp_*.jpeg
*.tmp

# DEV_MODE 검증 환경 (L3 인프라)
backend/dev.db
backend/dev.db-journal
backend/dev.db-shm
backend/dev.db-wal
docs/checklist/_evidence/
docs/checklist/_runs/

# analyzer (학생부 분석기) — 민감 데이터 및 OS별 바이너리
analyzer/input/
analyzer/output/
analyzer/tools/
analyzer/__pycache__/
analyzer/**/__pycache__/

# analyzer 학생 데이터 (실제 학생은 제외, 샘플·템플릿만 포함)
analyzer/data/students/*.py
!analyzer/data/students/_template.py
!analyzer/data/students/의대샘플.py
!analyzer/data/students/__init__.py

# 웹 업로드 파일 (민감 정보) — 통합 이식 전부터 누락되어 있던 이슈 보강
uploads/

# 로컬 Firebase 키 보관 폴더 (운영자 PC, google-services.json + 서비스 계정 키)
firebase/

# 로컬 Sentry DSN 메모 보관 폴더 (운영자 PC, write-only key 지만 정리 차원에서 ignore)
Sentry/
